+// Stub replacement for `wayland-backend` on Solaris.  The real crate
+// contains a bunch of Unix-specific polling/FD logic that doesn't build
+// on SunOS.  Codex itself doesn't actually use any of the implementation
+// so an empty shell satisfies the dependency graph.
+
+// Reproduce the public module structure of the real crate so dependent
+// crates compile without changes.
+pub mod client {}
+pub mod server {}
+
+// export a dummy type that some consumers may mention in bounds.
+#[derive(Debug)]
+pub struct Backend;
+
+impl Backend {
+    /// Mimic the real constructor signature, but always succeed.
+    pub fn new() -> Result<Self, ()> {
+        Ok(Backend)
+    }
+}
