+        // On Solaris the tty descriptor may not be opened with O_NONBLOCK, which
+        // would cause read() to hang forever. Force non-blocking mode so we can
+        // detect WouldBlock and continue polling.
+        #[cfg(feature = "libc")]
+        unsafe {
+            let fd = input_fd.raw_fd();
+            let flags = libc::fcntl(fd, libc::F_GETFL);
+            if flags >= 0 {
+                libc::fcntl(fd, libc::F_SETFL, flags | libc::O_NONBLOCK);
+            }
+        }
